import java.security.MessageDigest;
import java.security.NoSuchAlgorithmException;
import java.sql.*;
import java.util.ArrayList;
import java.util.List;
import java.util.Random;
import java.util.Scanner;

public class PasswordStrengthAnalyzer {

    // Database credentials (Adjust according to your local setup)
    private static final String DB_URL = "jdbc:mysql://localhost:3306/password_db";
    private static final String DB_USER = "root";
    private static final String DB_PASSWORD = "password";
    private static Connection connection = null;

    public static void main(String[] args) {
        initializeDatabase();
        Scanner scanner = new Scanner(System. some.in);
        
        System.out.println("=== Password Strength Analyzer ===");
        System.out.print("Enter your username: ");
        String username = scanner.nextLine().trim();

        System.out.print("Enter the password to analyze: ");
        String password = scanner.nextLine();

        System.out.println("\n--- Analyzing ---");
        
        // 1. Check Uniqueness / History
        boolean isReused = checkIfPasswordReused(username, password);
        if (isReused) {
            System.out.println("❌ Security Risk: You have used this password before! Please choose a new one.");
        }

        // 2. Evaluate Strength
        List<String> feedback = evaluatePasswordStrength(password);

        if (feedback.isEmpty() && !isReused) {
            System.out.println("✨ Strong Password! Your password meets all security criteria.");
            // Store the password hash securely
            savePasswordToHistory(username, password);
        } else {
            System.out.println("⚠️ Weak/Moderate Password. Issues found:");
            for (String issue : feedback) {
                System.out.println("  - " + issue);
            }
            
            // 3. Suggest Alternative
            System.out.println("\n💡 Suggested Strong Alternative: " + generateAlternativePassword());
        }

        scanner.close();
        closeDatabaseConnection();
    }

    /**
     * Evaluates length, complexity, and basic predictability patterns
     */
    private static List<String> evaluatePasswordStrength(String password) {
        List<String> feedback = new ArrayList<>();

        // Length Check
        if (password.length() < 8) {
            feedback.add("Password is too short (Must be at least 8 characters long).");
        }

        // Complexity Checks
        if (!password.matches(".*[A-Z].*")) {
            feedback.add("Missing at least one uppercase letter (A-Z).");
        }
        if (!password.matches(".*[a-z].*")) {
            feedback.add("Missing at least one lowercase letter (a-z).");
        }
        if (!password.matches(".*[0-9].*")) {
            feedback.add("Missing at least one numerical digit (0-9).");
        }
        if (!password.matches(".*[!@#$%^&*()_+\\-=\\[\\]{};':\",.<>/?].*")) {
            feedback.add("Missing at least one special character (e.g., !, @, #, $).");
        }

        // Predictability / Common sequences
        if (password.toLowerCase().contains("123") || password.toLowerCase().contains("password") || password.toLowerCase().contains("qwerty")) {
            feedback.add("Password contains easily guessable common sequences.");
        }

        return feedback;
    }

    /**
     * Generates a randomized, secure 12-character alternative password
     */
    private static String generateAlternativePassword() {
        String upperChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        String lowerChars = "abcdefghijklmnopqrstuvwxyz";
        String digits = "0123456789";
        String specialChars = "!@#$%^&*(_+=-)";
        String allChars = upperChars + lowerChars + digits + specialChars;

        Random rand = new Random();
        StringBuilder alternative = new StringBuilder();

        // Guaranteeing at least one of each rule
        alternative.append(upperChars.charAt(rand.nextInt(upperChars.length())));
        alternative.append(lowerChars.charAt(rand.nextInt(lowerChars.length())));
        alternative.append(digits.charAt(rand.nextInt(digits.length())));
        alternative.append(specialChars.charAt(rand.nextInt(specialChars.length())));

        // Populate the rest up to 12 characters
        for (int i = 4; i < 12; i++) {
            alternative.append(allChars.charAt(rand.nextInt(allChars.length())));
        }

        // Shuffle the characters slightly so the pattern isn't fixed
        char[] passwordArray = alternative.toString().toCharArray();
        for (int i = 0; i < passwordArray.length; i++) {
            int j = rand.nextInt(passwordArray.length);
            char temp = passwordArray[i];
            passwordArray[i] = passwordArray[j];
            passwordArray[j] = temp;
        }

        return new String(passwordArray);
    }

    /**
     * Hashes password using SHA-256 for secure cryptographic verification
     */
    private static String hashPassword(String password) {
        try {
            MessageDigest digest = MessageDigest.getInstance("SHA-256");
            byte[] hashBytes = digest.digest(password.getBytes());
            StringBuilder hexString = new StringBuilder();
            for (byte b : hashBytes) {
                String hex = Integer.toHexString(0xff & b);
                if (hex.length() == 1) hexString.append('0');
                hexString.append(hex);
            }
            return hexString.toString();
        } catch (NoSuchAlgorithmException e) {
            throw new RuntimeException("Error securely hashing password", e);
        }
    }

    // ==========================================
    // DATABASE / JDBC MANAGEMENT
    // ==========================================

    private static void initializeDatabase() {
        try {
            connection = DriverManager.getConnection(DB_URL, DB_USER, DB_PASSWORD);
            Statement stmt = connection.createStatement();
            
            // Create table if it doesn't exist
            String query = "CREATE TABLE IF NOT EXISTS password_history (" +
                           "id INT AUTO_INCREMENT PRIMARY KEY, " +
                           "username VARCHAR(50), " +
                           "password_hash VARCHAR(64)" +
                           ")";
            stmt.executeUpdate(query);
        } catch (SQLException e) {
            System.out.println("⚠️ Database Connection Failed: Proceeding in offline evaluation mode.");
        }
    }

    private static boolean checkIfPasswordReused(String username, String password) {
        if (connection == null) return false; 
        
        String currentHash = hashPassword(password);
        String query = "SELECT * FROM password_history WHERE username = ? AND password_hash = ?";
        
        try (PreparedStatement pstmt = connection.prepareStatement(query)) {
            pstmt.setString(1, username);
            pstmt.setString(2, currentHash);
            ResultSet rs = pstmt.executeQuery();
            return rs.next(); // Returns true if a record already exists
        } catch (SQLException e) {
            return false;
        }
    }

    private static void savePasswordToHistory(String username, String password) {
        if (connection == null) return;

        String hash = hashPassword(password);
        String query = "INSERT INTO password_history (username, password_hash) VALUES (?, ?)";
        
        try (PreparedStatement pstmt = connection.prepareStatement(query)) {
            pstmt.setString(1, username);
            pstmt.setString(2, hash);
            pstmt.executeUpdate();
            System.out.println("💾 Password securely added to your history tracking.");
        } catch (SQLException ignored) {}
    }

    private static void closeDatabaseConnection() {
        try {
            if (connection != null && !connection.isClosed()) {
                connection.close();
            }
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}
